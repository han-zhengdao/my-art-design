# 【通用】环境变量

#  版本号
VITE_VERSION = 3.0.2

# 端口号
VITE_PORT = 3006

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# 权限模式【 frontend 前端模式 / backend 后端模式 】（后端模式：左侧菜单由 /auth/getMyMenus 驱动）
VITE_ACCESS_MODE = backend

# 跨域请求时是否携带 Cookie（开启前需确保后端支持）
VITE_WITH_CREDENTIALS = false

# 是否打开路由信息
VITE_OPEN_ROUTE_INFO = false

# 锁屏加密密钥
VITE_LOCK_ENCRYPT_KEY = s3cur3k3y4adpro

# 地图（查看地图页）：可只填 KEY，或填完整 script 地址（优先使用 *_SCRIPT_SRC）
# 腾讯地图：https://lbs.qq.com/
# 谷歌地图：https://developers.google.com/maps/documentation
VITE_TENCENT_MAP_KEY = 'P6IBZ-YH263-D633I-OYO2S-2Q6NH-I4BTW'
VITE_TENCENT_MAP_SCRIPT_SRC = `https://map.qq.com/api/gljs?v=1.exp&key=P6IBZ-YH263-D633I-OYO2S-2Q6NH-I4BTW&libraries=geometry,service`
VITE_GOOGLE_MAP_KEY = 'AIzaSyC2SFNiptmUXyNQNO4Se5S7d2_A7tCOFT4'
VITE_GOOGLE_MAP_SCRIPT_SRC = `https://maps.googleapis.com/maps/api/js?key=${VITE_GOOGLE_MAP_KEY}&libraries=places,drawing`
